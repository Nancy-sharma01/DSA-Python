class Solution(object):
    def isValid(self, s):
        """
        :type s: str
        :rtype: bool
        """
        pairs={
            ')':'(',
            ']':'[',
            '}':'{'
        }
        stack=[]

        for ch in s:
            if ch in pairs.values():
                stack.append(ch)
            elif ch in pairs:
                expected=pairs[ch]
                if not stack:
                    return False
                elif stack[-1]==expected:
                    stack.pop()
                else:
                    return False

        
        return len(stack) == 0
            
